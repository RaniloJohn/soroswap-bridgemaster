// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SwapIntent {
  id        String   @id @default(uuid())
  hashlock  String   @unique
  sender    String
  receiver  String
  token     String
  amount    String
  timelock  Int
  status    String   @default("PENDING") // PENDING, LOCKED, CLAIMED, REFUNDED
  preimage  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
